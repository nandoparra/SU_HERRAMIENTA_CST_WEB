# Base de datos
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=b2csuherramienta
# DB_PORT=3306  # solo necesario si es distinto a 3306 (ej: Railway usa 23534)

# Servidor
PORT=3001
NODE_ENV=development

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-api03-...
# CLAUDE_MODEL=claude-sonnet-4-6

# IVA (decimal: 0.19 = 19%). Por defecto 0.
# IVA_RATE=0

# API key opcional (protege todos los endpoints /api/*)
# Si se define, enviar header: x-api-key: <valor>
# API_SECRET_KEY=

# Sesiones - requerido en produccion. Usar cadena larga y aleatoria.
SESSION_SECRET=cambia-esto-por-algo-secreto

# Panel superadmin - requerido en produccion.
# SUPERADMIN_SECRET=cambia-esto-por-algo-secreto

# WhatsApp - numero del encargado de repuestos (sin +, sin espacios, ej: 573104650437)
# PARTS_WHATSAPP_NUMBER=573100000000

# Ruta de autenticacion WhatsApp Web (sesion persistente)
# En Railway apuntar a un Volume: /data/.wwebjs_auth
# WA_AUTH_PATH=./.wwebjs_auth

# Ruta base de uploads (fotos, informes, facturas)
# En Railway apuntar a un Volume: /data/uploads
# UPLOADS_PATH=./public/uploads

# HTTPS redirect via proxy inverso (nginx, Render, Railway, etc.)
# Activar solo si el servidor esta detras de un proxy que termina TLS.
# BEHIND_PROXY=true
